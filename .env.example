# GitHub integration
GITHUB_ORG=openKG-field
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repository
GITHUB_TOKEN=

# LLM integration (OpenAI-compatible API; can point to free/community model providers)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_CHAT_PATH=/v1/chat/completions
LLM_TIMEOUT_SECONDS=60

# Public gateway behavior
ENABLE_API_DOCS=false

# Example provider (replace with your real key/model)
# OPENAI_COMPATIBLE_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_COMPATIBLE_MODEL=Qwen/Qwen2.5-7B-Instruct

# Optional metadata
HF_ORG=https://huggingface.co/your-org
OPENKG_REFERENCE=https://www.openkg.cn/

# Optional resource persistence (used by resource-service)
RESOURCE_DB_FILE=/app/data/community.db

# Public deployment (used by docker-compose.public.yml + Caddy)
DOMAIN=your-domain.com

