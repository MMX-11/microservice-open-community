      "sections": [
        {
          "id": "reading-context",
          "title": "背景与目标",
          "body": "站点目标是统一承载任务评测、项目协作、知识沉淀和社区讨论。核心追求是让研究内容从“论文与仓库分离”转向“任务-数据-算法-讨论一体化”。",
          "highlights": [
            "以四大模块构成首页信息骨架",
            "所有条目提供 GitHub 深入入口",
            "通过免费大模型辅助运营更新"
          ],
          "references": [
            {
              "label": "openKG-field",
              "url": "https://github.com/openKG-field"
            }
          ]
        },
        {
          "id": "reading-architecture",
          "title": "架构设计与微服务策略",
          "body": "采用 API 网关聚合 community/benchmark/resource/llm 多服务。通过容器化部署提升迁移与扩缩效率，后续可接入 Kubernetes 做可视化运维和自动伸缩。",
          "highlights": [
            "API 网关统一对外接口",
            "资源服务承担知识库与分类中心",
            "社区服务负责 GitHub 组织联动"
          ],
          "references": [
            {
              "label": "微服务容器化论文 DOI",
              "url": "https://doi.org/10.11907/rjdk.221677"
            }
          ]
        },
        {
          "id": "reading-ux",
          "title": "阅读体验与信息组织",
          "body": "采用分层阅读结构，将复杂信息拆分为“目录 + 主文 + 外链”。结合知识表与联动视图，支持管理者快速定位内容并持续补充。",
          "highlights": [
            "阅读页强调章节导览与锚点跳转",
            "知识表强调筛选、状态、标签",
            "联动视图强调论文-项目-数据集关系"
          ],
          "references": [
            {
              "label": "信息分层设计示例",
              "url": "https://zread.ai/instructkr/claude-code/3-source-snapshot-background"
            }
          ]
        },
        {
          "id": "reading-ops",
          "title": "运营闭环",
          "body": "管理员新增内容时，先归类再打标签，再将链接写入数据库。每条内容可通过模型生成发布摘要，并在论坛模块组织讨论与复盘。",
          "highlights": [
            "内容新增改为后端持久化",
            "支持社区演进与审计留痕",
            "可按模块形成周报或月报"
